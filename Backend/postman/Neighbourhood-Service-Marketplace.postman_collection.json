        {
          "name": "Get Providers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/providers?location=Delhi"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "Create Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.service && data.data.service._id) {",
                  "  pm.environment.set('serviceId', data.data.service._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Plumbing Repair\",\n  \"description\": \"Fix leaks and pipes\",\n  \"category\": \"plumber\",\n  \"price\": 800,\n  \"location\": \"Delhi\"\n}"
            },
            "url": "{{baseUrl}}/services"
          },
          "response": []
        },
        {
          "name": "Get Services (Filtered)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/services?keyword=plumber&page=1&limit=10&sortBy=price&order=asc"
          },
          "response": []
        },
        {
          "name": "Get Service By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/services/{{serviceId}}"
          },
          "response": []
        },
        {
          "name": "Update Service",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 950\n}"
            },
            "url": "{{baseUrl}}/services/{{serviceId}}"
          },
          "response": []
        },
        {
          "name": "Delete Service (Optional Cleanup)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{providerToken}}"
              }
            ],
            "url": "{{baseUrl}}/services/{{serviceId}}"
          },
          "response": []
        }
      ]
    },
